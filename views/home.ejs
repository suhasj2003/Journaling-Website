<%- include("partials/header") -%>
<h1>Home</h1>
<p><%= homeStartingValue %></p>

<% posts.forEach(function(post) { %>
  <h1><%= post.postTitle %></h1>
  <% if (post.postContent.length > 100) { %>
    <p><%= post.postContent.substring(0,100) + "..." %> <a href="/posts/<%= post.postTitle %>" >Read More</a></p>
  <% } else { %>
    <p><%= post.postContent %> <a href="/posts/<%= post.postTitle%>" >Read More</a></p>
  <% } %>
<% }); %>

<%- include("partials/footer") -%>
